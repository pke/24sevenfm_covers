#!/bin/sh
# Per-module semantic-version bump from Conventional Commits.
#
# Each shipped binary has its OWN version header. A commit bumps a binary iff it touches
# that binary's code OR the shared code (lib/, shared/). The commit type sets the size:
#   fix: / perf: -> patch     feat: -> minor     feat! / BREAKING CHANGE -> major
# Other types (chore/docs/refactor/test/ci/style/build) do not bump.
#
# perf: bumps because it changes SHIPPED code, and a released binary must never be quietly
# replaced by different bytes under the same version. Types that never reach a binary
# (docs, ci, test, chore) don't bump; refactor: doesn't either, being behaviour-preserving
# by definition - if it isn't, it wasn't a refactor.
#
#   Shared    lib/**, shared/**                    -> bumps ALL three modules
#   Winamp    winamp/**                            -> winamp/gen_version.h
#   foobar    foobar2000/foo_24sevenfm_covers/**   -> .../foo_version.h
#   Desktop   desktop/**                           -> desktop/viewer_version.h
#   (installer/, lib/tests/, docs, *.md, the version files themselves -> no bump)
#
# The bump is folded into the same commit (amend). Enable once per clone:
#   git config core.hooksPath .githooks

GUARD=".git/.ssc-version-bumping"
# The amend below re-triggers post-commit; this guard stops the recursion.
if [ -f "$GUARD" ]; then rm -f "$GUARD"; exit 0; fi

subject=$(git log -1 --pretty=%s)
body=$(git log -1 --pretty=%B)

bump=""
if printf '%s\n' "$body" | grep -qiE '^BREAKING[ -]CHANGE' \
   || printf '%s' "$subject" | grep -qE '^[a-zA-Z]+(\([^)]*\))?!:'; then
  bump=major
elif printf '%s' "$subject" | grep -qE '^feat(\([^)]*\))?:'; then
  bump=minor
elif printf '%s' "$subject" | grep -qE '^(fix|perf)(\([^)]*\))?:'; then
  bump=patch
fi
[ -z "$bump" ] && exit 0

# Files changed in the commit just made; classify each into a module bucket.
shared=0; winamp=0; foobar=0; desktop=0
for f in $(git diff-tree --no-commit-id --name-only -r HEAD); do
  case "$f" in
    lib/tests/*)                                        ;;  # tests do not ship
    lib/*|shared/*)                             shared=1 ;; # shared -> all modules
    winamp/gen_version.h)                               ;;  # ignore the version files themselves
    winamp/*)                                   winamp=1 ;;
    foobar2000/foo_24sevenfm_covers/foo_version.h)      ;;
    foobar2000/foo_24sevenfm_covers/*)          foobar=1 ;;
    desktop/viewer_version.h)                           ;;
    desktop/*)                                  desktop=1 ;;
    *)                                                  ;;  # installer/, docs, etc. -> no bump
  esac
done

# Shared code fans out to every module.
if [ "$shared" = 1 ]; then winamp=1; foobar=1; desktop=1; fi
[ "$winamp" = 0 ] && [ "$foobar" = 0 ] && [ "$desktop" = 0 ] && exit 0

# Rewrite one module's SSC_VER_* lines by $bump.
bump_file() {
  vf="$1"; label="$2"
  [ -f "$vf" ] || return 0
  maj=$(sed -n 's/^#define SSC_VER_MAJOR \([0-9][0-9]*\).*/\1/p' "$vf")
  min=$(sed -n 's/^#define SSC_VER_MINOR \([0-9][0-9]*\).*/\1/p' "$vf")
  pat=$(sed -n 's/^#define SSC_VER_PATCH \([0-9][0-9]*\).*/\1/p' "$vf")
  case "$bump" in
    major) maj=$((maj + 1)); min=0; pat=0 ;;
    minor) min=$((min + 1)); pat=0 ;;
    patch) pat=$((pat + 1)) ;;
  esac
  sed -i \
    -e "s/^#define SSC_VER_MAJOR .*/#define SSC_VER_MAJOR $maj/" \
    -e "s/^#define SSC_VER_MINOR .*/#define SSC_VER_MINOR $min/" \
    -e "s/^#define SSC_VER_PATCH .*/#define SSC_VER_PATCH $pat/" \
    -e "s/^#define SSC_VER_NUM .*/#define SSC_VER_NUM   $maj, $min, $pat, 0/" \
    -e "s/^#define SSC_VER_STR .*/#define SSC_VER_STR   \"$maj.$min.$pat\"/" \
    "$vf"
  git add "$vf"
  echo "  $label -> $maj.$min.$pat"
}

echo "[version] $bump bump:"
[ "$winamp" = 1 ]  && bump_file "winamp/gen_version.h"                          "winamp "
[ "$foobar" = 1 ]  && bump_file "foobar2000/foo_24sevenfm_covers/foo_version.h" "foobar "
[ "$desktop" = 1 ] && bump_file "desktop/viewer_version.h"                     "desktop"

: > "$GUARD"
git commit --amend --no-edit --no-verify >/dev/null 2>&1
