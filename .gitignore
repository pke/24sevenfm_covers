# Build & distribution output
/winamp/build/
/foobar2000/foo_24sevenfm_covers/build/
/lib/build/
/lib/build-tests/
/lib/build-android-*/
/x64/
/desktop/build/
*.aps

# Vendored deps are committed as SOURCE (foobar2000/sdk/, foobar2000/wtl/). Ignore
# only their build output, not the trees themselves - a blocklist, not an allowlist.
foobar2000/sdk/**/x64/**
foobar2000/sdk/**/[Ww]in32/**
foobar2000/sdk/**/[Dd]ebug/**
foobar2000/sdk/**/[Rr]elease/**
foobar2000/sdk/**/.vs/**
foobar2000/sdk/**/*.dll
# (shared/shared-*.lib is a REQUIRED import library, not build output - keep it)

# Visual Studio / tooling
*.user
*.suo
.vs/

# Local Claude Code settings (holds secrets like API keys - never commit)
.claude/settings.local.json

# Runtime log written by both plugins
24seven.fm-covers*.log

# Website: generated output (gh-pages root), rendered from site/ by
# build_artifacts.ps1 (local preview) or the release workflow
/www/

# Windows Explorer thumbnail cache
Thumbs.db
