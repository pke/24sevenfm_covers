// options_page.rc - the shared options dialog, #included by each host's .rc so the
// layout is defined once. A child dialog (DS_CONTROL | WS_CHILD): Winamp hosts it as
// the "Options" tab page, foobar2000 as its preferences page. Control logic lives in
// shared/options_panel.cpp.
#include <windows.h>
#include <commctrl.h>
#include "options_ids.h"

IDD_OPTIONS_PAGE DIALOGEX 0, 0, 205, 116
STYLE DS_CONTROL | WS_CHILD
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Layout:",       -1,              8, 9, 40, 10, WS_GROUP
    AUTORADIOBUTTON "&Fill screen",  IDC_OPT_LAYOUT,   50, 8, 62, 10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "&Poster",       IDC_OPT_LAYOUT+1, 116, 8, 50, 10

    AUTOCHECKBOX    "Show &remaining time", IDC_OPT_OVERLAY, 8, 24, 190, 12, WS_GROUP | WS_TABSTOP

    LTEXT           "Size:",         -1,              8, 41, 40, 10, WS_GROUP
    AUTORADIOBUTTON "S&mall",        IDC_OPT_SIZE,     50, 40, 40, 10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "M&edium",       IDC_OPT_SIZE+1,   92, 40, 46, 10
    AUTORADIOBUTTON "&Large",        IDC_OPT_SIZE+2,   140, 40, 44, 10

    AUTOCHECKBOX    "&Animate the countdown digits (rolling)",   IDC_OPT_ROLL,    8, 56, 190, 12, WS_GROUP | WS_TABSTOP

    LTEXT           "Transition:",   -1,              8, 73, 42, 10, WS_GROUP
    AUTORADIOBUTTON "&None",         IDC_OPT_TRANS,    50, 72, 32, 10, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "&Crossfade",    IDC_OPT_TRANS+1,  84, 72, 50, 10
    AUTORADIOBUTTON "Flip &H",       IDC_OPT_TRANS+2,  136, 72, 32, 10
    AUTORADIOBUTTON "Flip &V",       IDC_OPT_TRANS+3,  170, 72, 32, 10

    LTEXT           "Duration:",     -1,              8, 92, 40, 10, WS_GROUP
    CONTROL         "", IDC_OPT_FADE, "msctls_trackbar32",
                    TBS_HORZ | TBS_AUTOTICKS | WS_TABSTOP,                       50, 89, 116, 18
    LTEXT           "500 ms",        IDC_OPT_FADEVAL, 170, 92, 30, 10
END
